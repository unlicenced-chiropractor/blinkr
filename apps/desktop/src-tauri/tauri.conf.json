{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blinkr",
  "version": "0.1.0",
  "identifier": "com.blinkr.app",
  "build": {
    "beforeDevCommand": "npm run dev -w @blinkr/web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build -w @blinkr/web",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Blinkr",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Fast, modern text messaging",
    "longDescription": "Blinkr is a clean, fast messaging app focused entirely on text chat with friends and groups.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {}
}
